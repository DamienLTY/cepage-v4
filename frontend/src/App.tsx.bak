type Page = 'home' | 'search' | 'events' | 'admin' | 'favorites' | 'account' | 'login' | 'register' | 'verify-email' | 'reset-password';

// ── FAVORIS — localStorage ──────────────────────────────────
const FAV_KEY = 'cepage_favorites';
function getFavorites(): WineResult[] {
  try { return JSON.parse(localStorage.getItem(FAV_KEY) || '[]'); } catch { return []; }
}
function saveFavorites(favs: WineResult[]) {
  localStorage.setItem(FAV_KEY, JSON.stringify(favs.slice(0, 50)));
}
function isFavorite(wine: WineResult): boolean {
  return getFavorites().some(f => f.foundName === wine.foundName);
}
function toggleFavorite(wine: WineResult): boolean {
  const favs = getFavorites();
  const idx = favs.findIndex(f => f.foundName === wine.foundName);
  if (idx >= 0) { favs.splice(idx, 1); saveFavorites(favs); return false; }
  else { favs.unshift(wine); saveFavorites(favs); return true; }
}

