// ══════════════════════════════════════════════════════════════
// BULLES CHAMPAGNE — z-index -1 = derrière tout le contenu
// Spawn moins fréquent, zone circulaire élargie, dip puis montée
// ══════════════════════════════════════════════════════════════
function ChampagneBubbles({ disabled }: { disabled: boolean }) {
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const mouseRef = useRef({ x: -100, y: -100 });
  const bubblesRef = useRef<Array<{
    x: number; y: number; vy: number; vx: number;
    size: number; opacity: number; life: number; maxLife: number;
    popping: boolean; popFrame: number;
  }>>([]);

  useEffect(() => {
    if (disabled) return;
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const resize = () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight; };
    resize();
    window.addEventListener('resize', resize);

    const onMove = (e: MouseEvent) => { mouseRef.current = { x: e.clientX, y: e.clientY }; };
    const onTouch = (e: TouchEvent) => { if (e.touches[0]) mouseRef.current = { x: e.touches[0].clientX, y: e.touches[0].clientY }; };
    window.addEventListener('mousemove', onMove);
    window.addEventListener('touchmove', onTouch);

    let frame = 0;
    let rafId: number;

    const loop = () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      frame++;

      // Spawn depuis souris — zone circulaire de 50px, spawn moins fréquent (frame%9)
      if (mouseRef.current.x > 0 && frame % 9 === 0) {
        const angle = Math.random() * Math.PI * 2;
        const radius = 15 + Math.random() * 45; // Zone circulaire 15-60px
        const maxLife = 90 + Math.random() * 100;
        bubblesRef.current.push({
          x: mouseRef.current.x + Math.cos(angle) * radius,
          y: mouseRef.current.y + Math.sin(angle) * radius,
          vy: 0.8 + Math.random() * 0.5,  // Commence vers le bas (dip)
          vx: (Math.random() - 0.5) * 0.7,
          size: 2 + Math.random() * 3.5,
          opacity: 0.3 + Math.random() * 0.25,
          life: maxLife,
          maxLife,
          popping: false,
          popFrame: 0,
        });
      }

      // Ambient (remontent du bas) — moins fréquent aussi
      if (frame % 28 === 0) {
        const maxLife = 200 + Math.random() * 120;
        bubblesRef.current.push({
          x: Math.random() * canvas.width,
          y: canvas.height + 10,
          vy: -(0.4 + Math.random() * 0.8),
          vx: (Math.random() - 0.5) * 0.3,
          size: 1.5 + Math.random() * 2.5,
          opacity: 0.08 + Math.random() * 0.1,
          life: maxLife,
          maxLife,
          popping: false,
          popFrame: 0,
        });
      }

      bubblesRef.current = bubblesRef.current.filter(b => {
        // Pop aléatoire
        if (!b.popping && b.life < b.maxLife * 0.6 && Math.random() < 0.008) {
          b.popping = true;
          b.popFrame = 0;
        }

        if (b.popping) {
          b.popFrame++;
          const progress = b.popFrame / 12;
          const popSize = b.size * (1 + progress * 2.5);
          const popOpacity = b.opacity * (1 - progress);
          if (progress >= 1) return false;

          ctx.beginPath();
          ctx.arc(b.x, b.y, popSize, 0, Math.PI * 2);
          ctx.strokeStyle = `hsla(42, 55%, 72%, ${popOpacity * 0.6})`;
          ctx.lineWidth = 1;
          ctx.stroke();

          for (let i = 0; i < 4; i++) {
            const angle = (i / 4) * Math.PI * 2 + b.popFrame * 0.3;
            const dist = popSize * 0.8 * progress;
            ctx.beginPath();
            ctx.arc(b.x + Math.cos(angle) * dist, b.y + Math.sin(angle) * dist, 1, 0, Math.PI * 2);
            ctx.fillStyle = `hsla(42, 60%, 75%, ${popOpacity * 0.4})`;
            ctx.fill();
          }
          return true;
        }

        // Dip puis remontée progressive
        const age = b.maxLife - b.life;
        if (age < 10 && b.vy > 0) {
          b.vy -= 0.22; // Inverser vers le haut progressivement
        } else if (b.vy > -2) {
          b.vy -= 0.035; // Accélérer doucement vers le haut
        }
        b.x += b.vx + Math.sin(age * 0.08) * 0.3;
        b.y += b.vy;
        b.life--;
        b.opacity *= 0.997;

        if (b.life <= 0 || b.opacity < 0.015 || b.y < -20) return false;

        const alpha = Math.min(b.opacity, b.life / 25);

        // Bulle
        ctx.beginPath();
        ctx.arc(b.x, b.y, b.size, 0, Math.PI * 2);
        ctx.fillStyle = `hsla(42, 55%, 72%, ${alpha * 0.6})`;
        ctx.fill();

        // Reflet
        ctx.beginPath();
        ctx.arc(b.x - b.size * 0.25, b.y - b.size * 0.25, b.size * 0.35, 0, Math.PI * 2);
        ctx.fillStyle = `hsla(42, 60%, 85%, ${alpha * 0.35})`;
        ctx.fill();

        // Glow subtil
        ctx.beginPath();
        ctx.arc(b.x, b.y, b.size * 2.5, 0, Math.PI * 2);
        ctx.fillStyle = `hsla(42, 50%, 75%, ${alpha * 0.05})`;
        ctx.fill();

        return true;
      });

      // Limiter à 35 bulles max (moins de bulles = plus léger)
      if (bubblesRef.current.length > 35) bubblesRef.current = bubblesRef.current.slice(-35);
      rafId = requestAnimationFrame(loop);
    };

    rafId = requestAnimationFrame(loop);
    return () => {
      cancelAnimationFrame(rafId);
      window.removeEventListener('resize', resize);
      window.removeEventListener('mousemove', onMove);
      window.removeEventListener('touchmove', onTouch);
    };
  }, [disabled]);

  if (disabled) return null;

  return (
    <canvas
      ref={canvasRef}
      style={{ position: 'fixed', top: 0, left: 0, width: '100%', height: '100%', zIndex: -1, pointerEvents: 'none' }}
    />
  );
}

// ══════════════════════════════════════════════════════════════
// WINE DETAIL MODAL — popup détail vin scrappé depuis Hachette
// ══════════════════════════════════════════════════════════════
type WineDetailData = {
  ok: boolean; url: string;
  image?: string; wine_name?: string; year?: number; subtitle?: string;
  region?: string; appellation?: string; stars?: number; coup_de_coeur?: boolean;
  wine_type_label?: string; a_boire?: string; elevage?: string;
  garde?: string; temperature?: string; producer_url?: string;
};

function DetailBlock({ icon, label, value }: { icon: string; label: string; value: string }) {
  return (
    <div style={{
      background: 'rgba(212,175,55,0.09)', border: '1px solid rgba(212,175,55,0.22)',
      borderRadius: 10, padding: '8px 12px', flex: '1 1 110px', minWidth: 110
    }}>
      <div style={{ fontSize: '0.68rem', color: 'rgba(60,40,10,0.5)', marginBottom: 2, textTransform: 'uppercase', letterSpacing: '0.06em' }}>
        {icon} {label}
      </div>
      <div style={{ fontSize: '0.85rem', color: '#2D0A0D', fontWeight: 600 }}>{value}</div>
    </div>
  );
}

function WineDetailModal({ url, onClose, onDetailLoaded }: { url: string; onClose: () => void; onDetailLoaded?: (url: string, data: WineDetailData) => void }) {
  const [data, setData] = useState<WineDetailData | null>(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);

  useEffect(() => {
    setLoading(true); setError(null); setData(null);
    fetch(`${BACKEND_URL}/api/wine/detail?url=${encodeURIComponent(url)}`)
      .then(r => r.json())
      .then(d => {
        setData(d);
        setLoading(false);
        if (d.ok && onDetailLoaded) onDetailLoaded(url, d);
      })
      .catch(() => { setError('Impossible de charger les détails'); setLoading(false); });
  }, [url]);

  useEffect(() => {
    const fn = (e: KeyboardEvent) => { if (e.key === 'Escape') onClose(); };
    document.addEventListener('keydown', fn);
    return () => document.removeEventListener('keydown', fn);
  }, [onClose]);

  return createPortal(
    <div
      style={{ position: 'fixed', top: 0, left: 0, right: 0, bottom: 0, background: 'rgba(0,0,0,0.6)', zIndex: 9999, display: 'flex', alignItems: 'center', justifyContent: 'center', padding: 16 }}
      onClick={onClose}
    >
      <div
        style={{ background: '#f8f4ec', borderRadius: 20, maxWidth: 460, width: '100%', maxHeight: '90vh', overflow: 'auto', boxShadow: '0 24px 80px rgba(0,0,0,0.5)', position: 'relative' }}
        onClick={e => e.stopPropagation()}
      >
        <button onClick={onClose} style={{ position: 'absolute', top: 12, right: 12, zIndex: 2, background: 'rgba(45,10,13,0.1)', border: 'none', borderRadius: '50%', width: 32, height: 32, cursor: 'pointer', color: '#2D0A0D', fontSize: '1.2rem', lineHeight: '32px', textAlign: 'center' }}>×</button>

        {loading && (
          <div style={{ padding: 48, textAlign: 'center', color: 'rgba(45,10,13,0.45)' }}>
            <div style={{ fontSize: '2.5rem', marginBottom: 10 }}>🍷</div>
            Consultation de la fiche...
          </div>
        )}

        {error && !loading && (
          <div style={{ padding: 32, textAlign: 'center' }}>
            <p style={{ color: 'rgba(45,10,13,0.5)', marginBottom: 18, fontSize: '0.88rem' }}>{error}</p>
            <a href={url} target="_blank" rel="noopener noreferrer" className="more-info-link">Voir sur Hachette →</a>
          </div>
        )}

        {data?.ok && !loading && (
          <>
            {/* ── Header : image + infos principales ── */}
            <div style={{ display: 'flex', gap: 16, padding: '24px 24px 16px', borderBottom: '1px solid rgba(212,175,55,0.2)' }}>
              {data.image && (
                <img src={data.image} alt={data.wine_name}
                  style={{ width: 64, maxHeight: 130, objectFit: 'contain', borderRadius: 6, flexShrink: 0 }}
                  onError={e => { (e.target as HTMLImageElement).style.display = 'none'; }}
                />
              )}
              <div style={{ flex: 1, minWidth: 0, paddingRight: 28 }}>
                <h2 style={{ fontFamily: 'Playfair Display, serif', color: '#2D0A0D', fontSize: '1.1rem', fontWeight: 700, margin: 0, lineHeight: 1.25 }}>
                  {data.wine_name || '—'}
                </h2>
                {data.year && (
                  <p style={{ color: 'var(--bordeaux)', fontWeight: 700, fontSize: '1rem', margin: '4px 0 0' }}>
                    Millésime {data.year}
                  </p>
                )}
                {(data.appellation || data.region) && (
                  <p style={{ color: 'rgba(60,40,10,0.55)', fontSize: '0.78rem', margin: '5px 0 0' }}>
                    {[data.appellation, data.region].filter(Boolean).join(' · ')}
                  </p>
                )}
                <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginTop: 8, flexWrap: 'wrap' }}>
                  {data.stars !== undefined && data.stars > 0 && (
                    <span style={{ color: '#D4AF37', fontSize: '1.1rem', letterSpacing: 2 }}>{'★'.repeat(data.stars)}{'☆'.repeat(3 - data.stars)}</span>
                  )}
                  {data.coup_de_coeur && (
                    <span style={{ background: 'rgba(212,175,55,0.15)', border: '1px solid rgba(212,175,55,0.35)', borderRadius: 6, padding: '2px 8px', fontSize: '0.72rem', fontWeight: 600, color: '#7A5C1E' }}>
                      💛 Coup de Cœur
                    </span>
                  )}
                  {data.wine_type_label && (
                    <span style={{ background: 'rgba(114,47,55,0.09)', border: '1px solid rgba(114,47,55,0.18)', borderRadius: 6, padding: '2px 8px', fontSize: '0.72rem', color: 'var(--bordeaux)' }}>
                      {data.wine_type_label}
                    </span>
                  )}
                </div>
              </div>
            </div>

            {/* ── Blocs infos ── */}
            {(data.garde || data.temperature || data.elevage || data.a_boire) && (
              <div style={{ padding: '16px 20px', display: 'flex', flexWrap: 'wrap', gap: 10 }}>
                {data.garde && <DetailBlock icon="📅" label="Garde" value={data.garde} />}
                {data.temperature && <DetailBlock icon="🌡️" label="Température" value={data.temperature} />}
                {data.elevage && <DetailBlock icon="🪣" label="Élevage" value={data.elevage} />}
                {data.a_boire && <DetailBlock icon="🍷" label="Conseil" value={data.a_boire} />}
              </div>
            )}

            {/* ── Liens ── */}
            <div style={{ padding: '12px 20px 20px', display: 'flex', gap: 10, flexWrap: 'wrap', borderTop: '1px solid rgba(212,175,55,0.15)' }}>
              {data.producer_url && (
                <a href={data.producer_url} target="_blank" rel="noopener noreferrer"
                  style={{ padding: '7px 14px', borderRadius: 8, fontSize: '0.82rem', fontWeight: 500, background: 'rgba(212,175,55,0.12)', border: '1px solid rgba(212,175,55,0.3)', color: '#7A5C1E', textDecoration: 'none' }}
                >Fiche producteur →</a>
              )}
              <a href={url} target="_blank" rel="noopener noreferrer" className="more-info-link"
                style={{ padding: '7px 14px', fontSize: '0.82rem' }}
              >Voir sur Hachette →</a>
            </div>
          </>
        )}
      </div>
    </div>,
    document.body
  );
}

// ══════════════════════════════════════════════════════════════
// ÉTOILES BRILLANTES
// ══════════════════════════════════════════════════════════════
function Stars({ count }: { count: number }) {
  return (
    <span className="vintage-stars">
      {[0, 1, 2].map(i => (
        <span key={i} className={`star ${i < count ? 'filled' : 'empty'}`}>★</span>
      ))}
    </span>
  );
}

// ══════════════════════════════════════════════════════════════
// VINTAGE PILL
// ══════════════════════════════════════════════════════════════
function VintagePill({ v, onDetailClick, starOverride, highlightYear }: { v: WineVintage; onDetailClick?: (url: string) => void; starOverride?: number; highlightYear?: string }) {
  const colorClass = v.color === 'Rouge' ? 'rouge' : v.color === 'Rosé' ? 'rose' : 'blanc';
  const isEff = v.isEffervescent;
  const displayStars = starOverride !== undefined ? starOverride : v.stars;
  const isHighlighted = highlightYear && String(v.year) === highlightYear;

  const pill = (
    <div className={`vintage-pill ${colorClass} ${isEff ? 'effervescent' : ''}`} style={isHighlighted ? { 
      animation: 'glow-pulse 1s ease-in-out infinite alternate'
    } : undefined}>
      <span className="vintage-year" style={isHighlighted ? { 
        textShadow: '0 0 8px #ffd700, 0 0 16px #ffd700, 0 0 24px rgba(255,215,0,0.8)',
        color: '#ffd700'
      } : undefined}>{v.year}</span>
      <Stars count={displayStars} />
      {isEff && (
        <>
          <span className="eff-bubble" />
          <span className="eff-bubble" />
          <span className="eff-bubble" />
          <span className="eff-bubble" />
          <span className="eff-bubble" />
        </>
      )}
    </div>
  );

  if (v.link && onDetailClick) {
    return (
      <button onClick={() => onDetailClick(v.link!)} title="Voir les détails"
        style={{ background: 'none', border: 'none', padding: 0, cursor: 'pointer', display: 'inline-block' }}>
        {pill}
      </button>
    );
  }
  if (v.link) {
    return <a href={v.link} target="_blank" rel="noopener noreferrer" style={{ textDecoration: 'none' }}>{pill}</a>;
  }
  return pill;
}

// ══════════════════════════════════════════════════════════════
// RESULT CARD — "Plus d'infos" → lien recherche producteur
// ══════════════════════════════════════════════════════════════
function ResultCard({ result, onSimilarClick, onCompare, inCompare, highlightYear }: {
  result: WineResult;
  onSimilarClick: (n: string) => void;
  onCompare?: (r: WineResult) => void;
  inCompare?: boolean;
  highlightYear?: string;
}) {
  const [favored, setFavored] = useState(() => isFavorite(result));
  const [detailUrl, setDetailUrl] = useState<string | null>(null);
  const [starOverrides, setStarOverrides] = useState<Record<string, number>>({});

  const handleDetailLoaded = (url: string, detail: WineDetailData) => {
    if (detail.stars && detail.stars > 0) {
      setStarOverrides(prev => ({ ...prev, [url]: detail.stars! }));
    }
  };

  const byColor: Record<string, WineVintage[]> = {};
  for (const v of result.vintages) {
    const base = v.color || 'Autre';
    const c = v.isEffervescent ? `${base} effervescent` : base;
    if (!byColor[c]) byColor[c] = [];
    byColor[c].push(v);
  }
  for (const c of Object.keys(byColor)) byColor[c].sort((a, b) => b.year - a.year);

  const colorOrder = ['Rouge', 'Rouge effervescent', 'Rosé', 'Rosé effervescent', 'Blanc', 'Blanc effervescent', 'Autre'];
  const totalVintages = result.vintages.length;
  const appellations = [...new Set(result.vintages.map(v => v.type).filter(Boolean))];

  const moreInfoUrl = result.producerUrl
    || `https://www.hachette-vins.com/producteurs/page-1/list/?search=${encodeURIComponent(result.producerName || result.foundName)}`;

  const otherNames = result.vintages
    .map(v => v.name)
    .filter((n, i, a) => a.indexOf(n) === i && n !== result.foundName);

  const isRegionResult = result.passUsed === 'région';

  const handleFav = () => {
    const nowFav = toggleFavorite(result);
    setFavored(nowFav);
  };

  return (
    <div className="results-frame results-enter">
      <div className="result-header">
        <div>
          <h2 className="wine-name">{result.foundName}</h2>
          {result.producerName && result.producerName !== result.foundName && (
            <p style={{ margin: '2px 0 0', fontSize: '0.78rem', color: 'rgba(60,40,10,0.5)', fontStyle: 'italic', letterSpacing: '0.02em' }}>
              {result.producerName}
            </p>
          )}
          {appellations.length > 0 && (
            <p className="wine-appellation">
              {appellations.slice(0, 3).join(' · ')} — {totalVintages} millésime{totalVintages > 1 ? 's' : ''}
              {isRegionResult && <span style={{ marginLeft: 8, color: '#888', fontSize: '0.8rem' }}>• Résultat région</span>}
            </p>
          )}
        </div>
        <div style={{ display: 'flex', alignItems: 'center', gap: 8, flexShrink: 0 }}>
          {/* Bouton favoris */}
          <button
            onClick={handleFav}
            title={favored ? 'Retirer des favoris' : 'Ajouter aux favoris'}
            style={{
              background: favored ? 'rgba(180,30,30,0.1)' : 'rgba(60,40,10,0.05)',
              border: `1px solid ${favored ? 'rgba(180,30,30,0.3)' : 'rgba(60,40,10,0.15)'}`,
              borderRadius: 8, padding: '6px 10px', cursor: 'pointer',
              color: favored ? '#c0392b' : 'rgba(60,40,10,0.45)',
              fontSize: '1.1rem', lineHeight: 1, transition: 'all 0.2s',
            }}
          >{favored ? '♥' : '♡'}</button>
          {/* Bouton comparaison */}
          {onCompare && (
            <button
              onClick={() => onCompare(result)}
              title={inCompare ? 'Retirer de la comparaison' : 'Comparer ce vin'}
              style={{
                background: inCompare ? 'rgba(212,175,55,0.15)' : 'rgba(60,40,10,0.05)',
                border: `1px solid ${inCompare ? 'rgba(212,175,55,0.45)' : 'rgba(60,40,10,0.15)'}`,
                borderRadius: 8, padding: '5px 9px', cursor: 'pointer',
                color: inCompare ? '#7A5C1E' : 'rgba(60,40,10,0.45)',
                fontSize: '0.75rem', fontWeight: 600, letterSpacing: '0.03em', transition: 'all 0.2s',
              }}
            >{inCompare ? '✓ Comparé' : '⇄ Comparer'}</button>
          )}
          <a href={moreInfoUrl} target="_blank" rel="noopener noreferrer" className="more-info-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" />
            </svg>
            Plus d'infos
          </a>
        </div>
      </div>

      {colorOrder.map(color => {
        const vins = byColor[color];
        if (!vins || vins.length === 0) return null;
        const baseColor = color.replace(' effervescent', '');
        const isEff = color.endsWith(' effervescent');
        const cls = baseColor === 'Rouge' ? 'rouge' : baseColor === 'Rosé' ? 'rose' : 'blanc';
        const emoji = baseColor === 'Rouge' ? (isEff ? '🫧' : '🔴') : baseColor === 'Rosé' ? (isEff ? '🫧' : '🌸') : (isEff ? '🫧' : '🟡');
        const label = isEff ? `${baseColor} pétillant` : color;
        return (
          <div key={color} className="vintage-group">
            <div className={`vintage-group-title ${cls}`} style={isEff ? { opacity: 0.85, fontStyle: 'italic' } : undefined}>
              <span>{emoji}</span>
              {label} — {vins.length} millésime{vins.length > 1 ? 's' : ''}
            </div>
            <div className="vintages-grid">
              {vins.map((v, i) => <VintagePill key={`${v.year}-${v.color}-${i}`} v={v} onDetailClick={setDetailUrl} starOverride={v.link ? starOverrides[v.link] : undefined} highlightYear={highlightYear} />)}
            </div>
          </div>
        );
      })}

      {otherNames.length > 0 && (
        <div className="similar-section">
          <div className="similar-title">Autres vins du producteur</div>
          <div className="similar-list">
            {otherNames.slice(0, 8).map(name => (
              <button key={name} className="similar-chip" onClick={() => onSimilarClick(name)}>{name}</button>
            ))}
          </div>
        </div>
      )}

      {result.subWines && result.subWines.length > 0 && (
        <SubWinesSection subWines={result.subWines} onSimilarClick={onSimilarClick} onDetailClick={setDetailUrl} />
      )}

      {detailUrl && <WineDetailModal url={detailUrl} onClose={() => setDetailUrl(null)} onDetailLoaded={handleDetailLoaded} />}
    </div>
  );
}

function SubWinesSection({ subWines, onSimilarClick, onDetailClick }: { subWines: WineResult[]; onSimilarClick: (n: string) => void; onDetailClick?: (url: string) => void }) {
  return (
    <div style={{ display: 'flex', flexDirection: 'column', gap: 14, marginTop: 16 }}>
      {subWines.map((sw, i) => {
        const swByColor: Record<string, WineVintage[]> = {};
        for (const v of sw.vintages) {
          const c = v.color || 'Autre';
          if (!swByColor[c]) swByColor[c] = [];
          swByColor[c].push(v);
        }
        const colors = Object.keys(swByColor);
        const swUrl = sw.detailUrl || sw.vintages[0]?.link || '';
        return (
          <div key={i} style={{
            background: 'rgba(212,175,55,0.07)',
            borderRadius: 14,
            border: '1px solid rgba(212,175,55,0.28)',
            padding: '14px 18px'
          }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: 12 }}>
              <div>
                <h4 style={{ color: '#2D0A0D', fontSize: '1rem', fontWeight: 700, margin: 0, fontFamily: 'Playfair Display, serif' }}>
                  {sw.foundName}
                </h4>
                <p style={{ color: 'rgba(60,40,10,0.55)', fontSize: '0.78rem', margin: '3px 0 0' }}>
                  {sw.vintages.length} millésime{sw.vintages.length > 1 ? 's' : ''}
                </p>
              </div>
              <div style={{ display: 'flex', gap: 8, flexShrink: 0 }}>
                {swUrl && (
                  <a href={swUrl} target="_blank" rel="noopener noreferrer" style={{
                    display: 'flex', alignItems: 'center', gap: 5,
                    padding: '4px 10px', borderRadius: 7,
                    background: 'rgba(114,47,55,0.08)', border: '1px solid rgba(114,47,55,0.18)',
                    color: 'var(--bordeaux)', fontSize: '0.75rem', textDecoration: 'none', fontWeight: 500
                  }}>
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                      <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3" />
                    </svg>
                    Plus d'infos
                  </a>
                )}
                <button onClick={() => onSimilarClick(sw.foundName)} style={{
                  background: 'none', border: '1px solid rgba(60,40,10,0.18)',
                  borderRadius: 7, padding: '4px 10px',
                  color: 'rgba(60,40,10,0.65)', cursor: 'pointer', fontSize: '0.75rem'
                }}>
                  Rechercher
                </button>
              </div>
            </div>
            {colors.map(color => {
              const vins = swByColor[color].sort((a, b) => b.year - a.year).slice(0, 8);
              const cls = color === 'Rouge' ? 'rouge' : color === 'Rosé' ? 'rose' : 'blanc';
              return (
                <div key={color} style={{ marginBottom: 8 }}>
                  <div style={{ fontSize: '0.73rem', color: 'rgba(60,40,10,0.5)', marginBottom: 6 }}>
                    {color === 'Rouge' ? '🔴' : color === 'Rosé' ? '🌸' : '🟡'} {color}
                  </div>
                  <div style={{ display: 'flex', flexWrap: 'wrap', gap: 6 }}>
                    {vins.map((v, j) => {
                      const href = v.link || '';
                      const pill = (
                        <div className={`vintage-pill ${cls}`}>
                          <span className="vintage-year">{v.year}</span>
                          <Stars count={v.stars} />
                        </div>
                      );
                      if (href && onDetailClick) {
                        return <button key={j} onClick={() => onDetailClick(href)} style={{ background: 'none', border: 'none', padding: 0, cursor: 'pointer' }}>{pill}</button>;
                      }
                      return href
                        ? <a key={j} href={href} target="_blank" rel="noopener noreferrer" style={{ textDecoration: 'none' }}>{pill}</a>
                        : <span key={j}>{pill}</span>;
                    })}
                    {swByColor[color].length > 8 && (
                      <span style={{ color: 'rgba(60,40,10,0.4)', fontSize: '0.72rem', alignSelf: 'center' }}>
                        +{swByColor[color].length - 8}
                      </span>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        );
      })}
    </div>
  );
}

// ══════════════════════════════════════════════════════════════
// BARRE VENDANGE — progression fictive min 1.5s, max 3s
// ══════════════════════════════════════════════════════════════
function VendangeBar({ realDone, onComplete }: { realDone: boolean; onComplete: () => void }) {
  const [percent, setPercent] = useState(0);
  const [quote] = useState(() => WINE_QUOTES[Math.floor(Math.random() * WINE_QUOTES.length)]);
  const startTime = useRef(Date.now());
  const completed = useRef(false);

  useEffect(() => {
    const interval = setInterval(() => {
      const elapsed = Date.now() - startTime.current;

      if (realDone) {
        const minDuration = 1500;
        const remaining = Math.max(0, minDuration - elapsed);
        if (remaining > 0) {
          setPercent(p => Math.min(p + 5, 95));
        } else {
          setPercent(100);
          if (!completed.current) {
            completed.current = true;
            setTimeout(onComplete, 400);
          }
          clearInterval(interval);
        }
      } else {
        const maxDuration = 3000;
        const progress = Math.min(elapsed / maxDuration, 0.9);
        const eased = 1 - Math.pow(1 - progress, 2);
        setPercent(Math.floor(eased * 90));
        if (elapsed > maxDuration) setPercent(90);
      }
    }, 50);

    return () => clearInterval(interval);
  }, [realDone, onComplete]);

  return (
    <div className="vendange-container page-enter">
      <div className="vendange-bar">
        <div className="vendange-fill" style={{ width: `${percent}%` }} />
        <span className="vendange-percent">{percent}%</span>
      </div>
      <p className="vendange-quote">{quote}</p>
    </div>
  );
}

// ══════════════════════════════════════════════════════════════
// HOME PAGE
// ══════════════════════════════════════════════════════════════
function HomePage({
  onSearch,
  onRegionSearch,
  onNavigate
