  // Régions avec leurs emojis (key = clé BDD sans accents, name = affichage)
  const regions = [
    { key: 'Bordeaux',   name: 'Bordeaux',   emoji: '🏰' },
    { key: 'Bourgogne',  name: 'Bourgogne',  emoji: '🍇' },
    { key: 'Champagne',  name: 'Champagne',  emoji: '🥂' },
    { key: 'Alsace',     name: 'Alsace',     emoji: '🌹' },
    { key: 'Rhone',      name: 'Rhône',      emoji: '🌊' },
    { key: 'Loire',      name: 'Loire',      emoji: '🌻' },
    { key: 'Languedoc',  name: 'Languedoc',  emoji: '☀️' },
    { key: 'Provence',   name: 'Provence',   emoji: '🌿' },
    { key: 'Roussillon', name: 'Roussillon', emoji: '🏔️' },
    { key: 'Sud-Ouest',  name: 'Sud-Ouest',  emoji: '🌾' },
    { key: 'Beaujolais', name: 'Beaujolais', emoji: '🍷' },
    { key: 'Savoie',     name: 'Savoie',     emoji: '🏔️' },
